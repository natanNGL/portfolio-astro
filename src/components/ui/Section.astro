---
const { icon, title } = Astro.props;
import { Icon } from "astro-icon/components";
---

<section class="bg-section rounded-xl p-4 flex flex-col">
    <div class="flex gap-2 items-center border-b border-gray-700 pb-4 mb-4">
        {icon && <Icon name={icon} class="text-hijau text-2xl" />}
        <h3 class="text-lg text-white font-semibold">{title}</h3>
    </div>

    <slot />
</section>
