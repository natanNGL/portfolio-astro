---
import Data from "./../../data/card.json";
import { Icon } from "astro-icon/components";
import Contact from "./Contact.astro";

const { lang } = Astro.props as LangProps;
const { download } = Data;
---

<aside class="border border-section shadow-2xl flex flex-col justify-between bg-section rounded-xl gap-12 sm:flex-1">
    <div class="flex flex-col gap-10 p-2">
        <div class="overflow-hidden m-auto rounded-2xl mt-4 sm:w-4/5">
            <img src={"/images/profile_pic.jpg"} alt="profile" class="mx-auto" />
        </div>

        <div>
            <h3 class="text-hijau font-semibold text-center uppercase text-2xl">Roy Natanael. N</h3>
            <h5 class="text-putih text-center font-semibold text-lg">Software Engineer</h5>
        </div>
    </div>

    <Contact />

    <a
        download="Roy Natanael CV"
        target="_blank"
        href="/docs/cv.pdf"
        class="p-4 text-putih w-full text-center flex items-center gap-4 border-t border-gray-700 justify-center"
    >
        <Icon name="lucide:download" />
        <p>{download[lang]} CV</p>
    </a>
</aside>
